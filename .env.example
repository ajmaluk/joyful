# Unsplash (image search in the builder)
VITE_UNSPLASH_ACCESS_KEY=

# NVIDIA Nim (primary LLM provider)
# Get yours at https://build.nvidia.com/
VITE_JOYFUL_PROVIDER_ENABLED=true
VITE_NV_API_KEY=
VITE_NV_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions
VITE_NV_API_MODEL=qwen/qwen3-coder-480b-a35b-instruct
VITE_NV_API_FALLBACK_MODELS=qwen/qwen3-coder-480b-a35b-instruct
VITE_NV_TOP_P=0.8

# Groq (fallback when NVIDIA rate-limits)
VITE_GROQ_API_KEY=
VITE_GROQ_INVOKE_URL=https://api.groq.com/openai/v1/chat/completions
VITE_GROQ_API_MODEL=llama-3.1-8b-instant

# Firebase (auth & persistence)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
